# ============================================================
# TRADING HQ — ENVIRONMENT VARIABLES
# Paste these into Railway dashboard: Settings → Variables
# NEVER commit actual values to git
# ============================================================

# Supabase (you already have these)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# Alpaca (get from alpaca.markets dashboard)
ALPACA_API_KEY=your_alpaca_key
ALPACA_SECRET_KEY=your_alpaca_secret
ALPACA_BASE_URL=https://paper-api.alpaca.markets
# ^ Change to https://api.alpaca.markets for live trading

# Kalshi (get from Kalshi account settings → API)
KALSHI_KEY_ID=your_kalshi_key_id
KALSHI_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----
# ^ Paste the full PEM key with \n for newlines

# Perplexity (get from perplexity.ai/settings/api)
PERPLEXITY_API_KEY=pplx-your_key_here

# Anthropic (for Claude AI reasoning — you already have this)
ANTHROPIC_API_KEY=your_anthropic_key

# Telegram Alerts (optional but recommended)
TELEGRAM_BOT_TOKEN=your_bot_token_from_botfather
TELEGRAM_CHAT_ID=your_chat_id
